{
	"name": "woffu-checkin",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"description": "Script to fetch Woffu diaries and perform check-in based on differenceTime.",
	"bin": {
		"woffu-checkin": "dist/main.js"
	},
	"scripts": {
		"build": "tsc",
		"start": "tsx src/main.ts",
		"login": "tsx src/login.ts",
		"catchup": "tsx src/main.ts --catch-up",
		"lastweek": "tsx src/main.ts --last-week --catch-up",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsx": "^4.19.0",
		"typescript": "^5.5.0",
		"vitest": "^2.0.0"
	},
	"dependencies": {
		"chalk": "^5.6.2"
	}
}
